{
  "profile": "staging",
  "profile_version": "1",
  "environment": "staging",
  "validation_profile": "staging",
  "policy_profile": "staging",
  "deployment_root": "/home/mel/staging",
  "repository": "git@github.com:anna-pye/myeventlane-platform.git",
  "ssh": {
    "host": "staging",
    "user": "mel"
  },
  "paths": {
    "releases": "/home/mel/staging/releases",
    "shared": "/home/mel/staging/shared",
    "current": "/home/mel/staging/current",
    "logs": "/home/mel/staging/logs"
  },
  "executables": {
    "php": "php",
    "composer": "composer",
    "drush": "drush"
  },
  "verification": {
    "mode": "profile"
  },
  "health_endpoints": [],
  "required_approvals": [],
  "shared_resources": [],
  "plugins": {
    "composer": {
      "mode": "mock",
      "status": "passed"
    },
    "drush": {
      "mode": "mock",
      "status": "passed",
      "operations": [
        "updatedb",
        "cache_rebuild"
      ]
    },
    "health": {
      "mode": "mock",
      "status": "passed"
    },
    "shared": {
      "mode": "mock",
      "status": "passed"
    },
    "switch_current": {
      "mode": "mock",
      "status": "passed"
    }
  },
  "health_checks": [
    {
      "name": "staging_http_response",
      "type": "http_response",
      "required": true
    },
    {
      "name": "staging_drupal_status",
      "type": "drupal_status_endpoint",
      "required": true
    },
    {
      "name": "staging_root",
      "type": "directory_exists",
      "path": "/home/mel/staging",
      "required": true
    }
  ],
  "doctor_checks": [
    {
      "name": "ssh_connectivity",
      "type": "ssh_connectivity",
      "mode": "profile"
    },
    {
      "name": "deployment_root",
      "type": "deployment_root_exists",
      "mode": "profile"
    },
    {
      "name": "releases",
      "type": "releases_exists",
      "mode": "profile"
    },
    {
      "name": "shared",
      "type": "shared_exists",
      "mode": "profile"
    },
    {
      "name": "current",
      "type": "current_exists",
      "mode": "profile"
    },
    {
      "name": "logs",
      "type": "logs_exists",
      "mode": "profile"
    },
    {
      "name": "php_availability",
      "type": "php_availability",
      "mode": "profile"
    },
    {
      "name": "composer_availability",
      "type": "composer_availability",
      "mode": "profile"
    },
    {
      "name": "drush_availability",
      "type": "drush_availability",
      "mode": "profile"
    },
    {
      "name": "writable_release_root",
      "type": "writable_release_root",
      "mode": "profile"
    },
    {
      "name": "directory_layout",
      "type": "directory_layout",
      "mode": "profile"
    },
    {
      "name": "readable_shared_resources",
      "type": "readable_shared_resources",
      "mode": "profile"
    }
  ]
}
