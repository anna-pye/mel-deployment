{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "MEL Deployment Validation Manifest",
  "type": "object",
  "required": [
    "schema",
    "name",
    "repository",
    "paths"
  ],
  "properties": {
    "schema": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "deployment_id": {
      "type": "string"
    },
    "repository": {
      "type": "object",
      "required": [
        "name",
        "root"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "root": {
          "type": "string"
        },
        "url": {
          "type": "string"
        },
        "branch": {
          "type": "string"
        }
      }
    },
    "environment": {
      "type": "string"
    },
    "release": {
      "type": "object",
      "properties": {
        "strategy": {
          "type": "string"
        },
        "identifier": {
          "type": "string"
        }
      }
    },
    "paths": {
      "type": "object"
    },
    "validation_profile": {
      "type": "string"
    }
  }
}
